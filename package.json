{
  "name": "palaute",
  "version": "v3.27.0",
  "description": "Norppa is THE software for student feedback",
  "author": "Toska",
  "license": "MIT",
  "scripts": {
    "start": "docker compose up",
    "start:dev": "NODE_ENV=development concurrently -k \"npm run start:dev:server\" \"npm run start:dev:front\"",
    "start:dev:front": "vite",
    "start:dev:server": "tsx watch src/server/index.ts",
    "start:prod": "NODE_ENV=production node --max-old-space-size=4096 ./build/src/server/index.js",
    "start:test": "NODE_ENV=test node --max-old-space-size=4096 ./build/src/server/index.js",
    "build": "npm run clean-build && npm run build:server && npm run build:client",
    "build:client": "vite build",
    "build:server": "cross-env NODE_ENV=development && tsc --build src/server",
    "clean-build": "rimraf ./build",
    "test": "npm run test:setup && sleep 10 && npm run test:e2e",
    "test:setup": "docker compose down && docker compose -f docker-compose.ci.yml rm -vf && docker compose -f docker-compose.ci.yml up -d --build",
    "test:setuplocal": "docker compose -f docker-compose.test.yml up",
    "test:e2e": "CYPRESS_BASE_URL=http://localhost:8000 cypress run",
    "test:cypress": "cypress open",
    "test:run": "cypress run",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint --type-check .",
    "lint:fix": "oxlint --type-check --fix .",
    "lint:quiet": "oxlint --type-check --quiet .",
    "prepare": "husky",
    "translations": "node ./tools/analyzeTranslations.js",
    "ndc": "npx no-dead-code@latest --ignore config"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,cjs,mjs}": "oxlint --quiet",
    "**/*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "engines": {
    "node": "24.18.0"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "6.5.0",
    "@mui/material": "6.5.0",
    "@mui/utils": "6.4.9",
    "@mui/x-date-pickers": "7.29.4",
    "@sentry/browser": "8.55.0",
    "@sentry/node": "8.55.0",
    "@sentry/vite-plugin": "2.23.1",
    "@tanstack/react-query": "5.90.17",
    "@tanstack/react-query-devtools": "5.91.2",
    "@vitejs/plugin-react-swc": "3.11.0",
    "axios": "1.18.1",
    "buffer": "6.0.3",
    "chart.js": "4.5.1",
    "chartjs-adapter-date-fns": "3.0.0",
    "chartjs-plugin-annotation": "3.1.0",
    "chartjs-plugin-datalabels": "2.2.0",
    "compression": "1.8.1",
    "config": "3.3.12",
    "date-fns": "2.30.0",
    "date-fns-timezone": "0.1.4",
    "dotenv": "16.6.1",
    "express": "5.2.1",
    "formik": "2.4.9",
    "i18next": "26.3.6",
    "i18next-browser-languagedetector": "8.2.0",
    "i18next-fs-backend": "2.6.6",
    "i18next-http-backend": "3.0.5",
    "immer": "10.2.0",
    "intersection-observer": "0.12.2",
    "jsonwebtoken": "9.0.3",
    "lodash": "4.18.1",
    "lodash-es": "4.18.1",
    "morgan": "1.11.0",
    "node-cron": "3.0.3",
    "notistack": "3.0.2",
    "pg": "8.17.1",
    "qs": "6.15.2",
    "react": "19.2.3",
    "react-chartjs-2": "5.3.1",
