{
  "compilerOptions": {
    "module": "nodenext",
    "emitDeclarationOnly": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "target": "es6",
    "noImplicitAny": true,
    "moduleResolution": "nodenext",
    "sourceMap": true,
    "types": ["node"],
    "resolveJsonModule": true,
    "paths": {
      "@common/*": ["../common/*"]
    }
  },
  "include": ["./"],
  "extends": "../../tsconfig.json",
  "composite": true
}
